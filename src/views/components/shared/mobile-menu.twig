<div class="fixed inset-0 z-[100] hidden" data-mobile-menu>
    {# Backdrop #}
    <div class="absolute inset-0 bg-dark/60 backdrop-blur-sm" data-menu-toggle></div>
    
    {# Menu Content #}
    <div class="absolute top-0 right-0 w-[85%] max-w-sm h-full bg-white shadow-2xl flex flex-col">
        <div class="p-6 flex items-center justify-between border-b border-black/5">
             <a href="/" class="text-2xl font-bold text-primary flex items-center gap-1">
                <i class="salla-icon-heart-pulse"></i> Cody<span class="text-secondary">UI</span>
            </a>
            <button class="p-3 bg-soft-neutral rounded-xl" data-menu-toggle aria-label="Close">
                <i class="salla-icon-close text-xl"></i>
            </button>
        </div>
        
        <div class="flex-1 overflow-y-auto p-6">
            <nav class="flex flex-col space-y-6">
                {% for link in menu.main %}
                    <a href="{{ link.url }}" class="text-lg font-bold text-text-main hover:text-primary transition-colors flex items-center justify-between">
                        {{ link.title }}
                        <i class="salla-icon-arrow-left text-xs opacity-30"></i>
                    </a>
                {% endfor %}
            </nav>
            
            <div class="mt-12 pt-12 border-t border-black/5">
                <h4 class="text-[10px] font-bold text-text-muted uppercase tracking-widest mb-8">{{ 'account.profile'|trans }}</h4>
                <div class="space-y-6">
                    <a href="{{ user.login_url }}" class="flex items-center gap-4 text-sm font-bold">
                        <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-soft-neutral text-primary">
                            <i class="salla-icon-user text-xl"></i>
                        </div>
                        {{ 'account.login'|trans }}
                    </a>
                    <a href="{{ wishlist.url }}" class="flex items-center gap-4 text-sm font-bold">
                        <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-soft-neutral text-primary">
                            <i class="salla-icon-heart text-xl"></i>
                        </div>
                        {{ 'account.wishlist'|trans }}
                    </a>
                </div>
            </div>
        </div>
        
        <div class="p-6 border-t border-black/5 bg-soft-neutral">
            <div class="flex items-center justify-center gap-6">
                {% for social in store.social %}
                    <a href="{{ social.url }}" class="text-text-muted hover:text-primary transition-colors">
                        <i class="salla-icon-{{ social.type }} text-xl"></i>
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
