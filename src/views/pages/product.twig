{% extends "layouts.master" %}

{% block content %}
    <div class="py-12 bg-soft-neutral">
        <div class="container mx-auto px-4">
            {# Breadcrumbs #}
            <nav class="flex items-center gap-2 text-[10px] font-bold text-text-muted uppercase tracking-widest mb-12">
                <a href="/" class="hover:text-primary transition-colors">الرئيسية</a>
                <i class="salla-icon-arrow-left text-[8px] opacity-30"></i>
                <a href="/category" class="hover:text-primary transition-colors">الفيتامينات</a>
                <i class="salla-icon-arrow-left text-[8px] opacity-30"></i>
                <span class="text-text-main">فيتامين سي 1000 مجم</span>
            </nav>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                {# Product Images #}
                <div class="space-y-6">
                    <div class="pharmacy-card aspect-square bg-white flex items-center justify-center p-12">
                        <img 
                            src="https://picsum.photos/seed/vit-c-main/800/800" 
                            alt="Product Image" 
                            class="w-full h-full object-contain"
                        >
                    </div>
                    <div class="grid grid-cols-4 gap-4">
                        {% for i in 1..4 %}
                            <div class="pharmacy-card aspect-square bg-white flex items-center justify-center p-4 cursor-pointer hover:border-primary transition-all">
                                <img src="https://picsum.photos/seed/vit-c-{{ i }}/200/200" alt="Thumb" class="w-full h-full object-contain">
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {# Product Info #}
                <div class="space-y-10">
                    <div>
                        <div class="flex items-center gap-4 mb-6">
                            <span class="text-xs font-bold text-primary uppercase tracking-widest">فيتامينات ومكملات</span>
                            {% if product.requires_prescription|default(true) %}
                                <span class="badge-prescription">
                                    <i class="salla-icon-prescription"></i>
                                    {{ 'product.requires_prescription'|trans }}
                                </span>
                            {% endif %}
                        </div>
                        <h1 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">فيتامين سي 1000 مجم - 60 قرص فوار لتعزيز المناعة</h1>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-1 text-warning">
                                {% for i in 1..5 %}
                                    <i class="salla-icon-star text-xs"></i>
                                {% endfor %}
                            </div>
                            <span class="text-xs font-bold text-text-muted">(45 مراجعة)</span>
                        </div>
                    </div>

                    <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm">
                        <div class="flex items-end gap-4 mb-8">
                            <span class="text-3xl font-bold text-primary">45.00 ر.س</span>
                            <span class="text-sm text-text-muted line-through mb-1">60.00 ر.س</span>
                            <span class="text-xs font-bold text-accent mb-1">(خصم 25%)</span>
                        </div>

                        <div class="space-y-6">
                            <div class="flex items-center gap-4">
                                <div class="flex items-center border border-black/10 rounded-lg overflow-hidden">
                                    <button class="w-12 h-12 flex items-center justify-center hover:bg-soft-neutral transition-colors"><i class="salla-icon-minus"></i></button>
                                    <input type="number" value="1" class="w-12 h-12 text-center font-bold text-sm border-x border-black/10 outline-none">
                                    <button class="w-12 h-12 flex items-center justify-center hover:bg-soft-neutral transition-colors"><i class="salla-icon-plus"></i></button>
                                </div>
                                <button class="flex-grow btn-pharmacy btn-primary h-12">
                                    <i class="salla-icon-cart-add mr-2"></i> {{ 'cart.add_to_cart'|trans }}
                                </button>
                            </div>
                            <button class="w-full btn-pharmacy btn-secondary h-12">
                                {{ 'cart.buy_now'|trans }}
                            </button>
                        </div>
                    </div>

                    {# Pharmacy Actions #}
                    <div class="grid grid-cols-2 gap-4">
                        <button class="p-6 rounded-xl bg-white border border-black/5 flex flex-col items-center text-center gap-4 hover:border-primary transition-all group" data-upload-prescription>
                            <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-all">
                                <i class="salla-icon-prescription text-xl"></i>
                            </div>
                            <span class="text-xs font-bold">{{ 'product.upload_prescription'|trans }}</span>
                        </button>
                        <button class="p-6 rounded-xl bg-white border border-black/5 flex flex-col items-center text-center gap-4 hover:border-secondary transition-all group">
                            <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-secondary/10 text-secondary group-hover:bg-secondary group-hover:text-white transition-all">
                                <i class="salla-icon-chat text-xl"></i>
                            </div>
                            <span class="text-xs font-bold">{{ 'product.pharmacist_support'|trans }}</span>
                        </button>
                    </div>

                    {# Product Details Tabs #}
                    {% include 'product.info-tabs' %}
                </div>
            </div>
        </div>
    </div>

    {# Sticky Add to Cart (Mobile) #}
    <div class="lg:hidden fixed bottom-0 left-0 right-0 p-4 bg-white border-t border-black/5 z-[60] shadow-2xl">
        <div class="flex items-center gap-4">
            <div class="flex flex-col leading-none">
                <span class="text-[10px] text-text-muted line-through">60.00 ر.س</span>
                <span class="text-lg font-bold text-primary">45.00 ر.س</span>
            </div>
            <button class="flex-grow btn-pharmacy btn-primary h-12">
                {{ 'cart.add_to_cart'|trans }}
            </button>
        </div>
    </div>

    {# Related Products #}
    <section class="py-24 bg-white">
        <div class="container mx-auto px-4">
            <h2 class="text-2xl font-bold mb-12">{{ 'product.related_products'|trans }}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                {% for i in 1..4 %}
                    {% include 'shared.product-card' with { product: {
                        name: 'فيتامين د3 5000 وحدة دولية - 60 كبسولة',
                        url: '/product',
                        image: {url: 'https://picsum.photos/seed/vit-d-' ~ i ~ '/400/400'},
                        category: {name: 'الفيتامينات'},
                        price: 35,
                        on_sale: false,
                        requires_prescription: false
                    }} %}
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
