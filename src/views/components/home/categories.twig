<section class="py-24 bg-light">
    <div class="container mx-auto px-4">
        {# Section Header #}
        <div class="text-center max-w-2xl mx-auto mb-16">
            <span class="text-primary text-xs font-bold tracking-widest uppercase mb-4 block">Categories</span>
            <h2 class="text-3xl md:text-4xl font-bold">{{ component.title|default('Shop by Category') }}</h2>
            <p class="text-gray-500 text-sm mt-4 leading-relaxed">
                {{ component.description|default('Explore our wide range of products across multiple categories.') }}
            </p>
        </div>

        {# Categories Grid #}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
            {% for category in categories.all|slice(0, 6) %}
                <a href="{{ category.url }}" class="group flex flex-col items-center p-8 bg-white rounded-3xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
                    <div class="w-20 h-20 flex items-center justify-center rounded-2xl bg-primary/5 group-hover:bg-primary group-hover:text-white transition-colors mb-6">
                        <i class="salla-icon-{{ category.icon|default('grid') }} text-3xl"></i>
                    </div>
                    <h3 class="text-sm font-bold text-dark group-hover:text-primary transition-colors">{{ category.name }}</h3>
                    <span class="text-[10px] font-bold text-gray-400 mt-2 uppercase tracking-widest">{{ category.products_count|default('0') }} Products</span>
                </a>
            {% else %}
                {# Placeholder for demo #}
                {% for i in 1..6 %}
                    <div class="animate-pulse flex flex-col items-center">
                        <div class="w-20 h-20 bg-white rounded-2xl mb-4"></div>
                        <div class="h-4 bg-white rounded w-full"></div>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </div>
</section>
