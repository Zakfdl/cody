{
  "version": "1.0.0",
  "theme_name": "CodyUI Pharmacy",
  "repo_url": "https://github.com/Zakfdl/cody",
  "support_url": "https://support.codyui.com",

  "settings": [
    {
      "type": "boolean",
      "label": "تفعيل RTL افتراضيًا",
      "id": "rtl_default",
      "format": "switch",
      "selected": true
    },
    {
      "type": "string",
      "label": "اللون الأساسي",
      "id": "primary_color",
      "format": "color",
      "value": "#00A884"
    },
    {
      "type": "string",
      "label": "اللون المساعد",
      "id": "accent_color",
      "format": "color",
      "value": "#007BFF"
    }
  ],

  "features": [
    "component-featured-products",
    "component-fixed-banner",
    "component-products-slider",
    "component-testimonials",
    "component-store-features",
    "filters"
  ],

  "components": [
    {
      "name": "pharmacy-hero",
      "title": "هيدر الصيدلية (CodyUI)",
      "icon": "sicon-image-carousel",
      "path": "home.pharmacy-hero",
      "fields": [
        {
          "id": "title",
          "type": "string",
          "label": "العنوان"
        },
        {
          "id": "subtitle",
          "type": "string",
          "format": "textarea",
          "label": "الوصف"
        },
        {
          "id": "image",
          "type": "string",
          "format": "image",
          "label": "صورة"
        }
      ]
    }
  ]
}