{% extends "layouts.master" %}

{% block content %}
    <div class="py-12 bg-soft-neutral">
        <div class="container mx-auto px-4">
            {# Breadcrumbs #}
            <nav class="flex items-center gap-2 text-[10px] font-bold text-text-muted uppercase tracking-widest mb-12">
                <a href="/" class="hover:text-primary transition-colors">الرئيسية</a>
                <i class="salla-icon-arrow-left text-[8px] opacity-30"></i>
                <span class="text-text-main">الفيتامينات والمكملات</span>
            </nav>

            <div class="flex flex-col lg:flex-row gap-12">
                {# Sidebar / Filters #}
                <aside class="w-full lg:w-64 flex-shrink-0 space-y-10">
                    <div>
                        <h4 class="text-sm font-bold uppercase tracking-widest mb-6">الأقسام الفرعية</h4>
                        <ul class="space-y-4">
                            <li><a href="#" class="text-sm font-bold text-primary flex items-center justify-between">فيتامينات المناعة <span class="text-[10px] opacity-30">(12)</span></a></li>
                            <li><a href="#" class="text-sm text-text-muted hover:text-primary transition-colors flex items-center justify-between">فيتامينات الأطفال <span class="text-[10px] opacity-30">(8)</span></a></li>
                            <li><a href="#" class="text-sm text-text-muted hover:text-primary transition-colors flex items-center justify-between">مكملات الطاقة <span class="text-[10px] opacity-30">(15)</span></a></li>
                            <li><a href="#" class="text-sm text-text-muted hover:text-primary transition-colors flex items-center justify-between">فيتامينات التجميل <span class="text-[10px] opacity-30">(20)</span></a></li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="text-sm font-bold uppercase tracking-widest mb-6">نطاق السعر</h4>
                        <div class="space-y-4">
                            <div class="flex items-center gap-4">
                                <input type="number" placeholder="من" class="w-full bg-white border border-black/5 rounded-lg px-4 py-3 text-sm outline-none">
                                <input type="number" placeholder="إلى" class="w-full bg-white border border-black/5 rounded-lg px-4 py-3 text-sm outline-none">
                            </div>
                            <button class="w-full btn-pharmacy btn-primary text-xs py-2">تطبيق</button>
                        </div>
                    </div>

                    <div>
                        <h4 class="text-sm font-bold uppercase tracking-widest mb-6">العلامة التجارية</h4>
                        <div class="space-y-4">
                            {% for brand in ['سولجار', 'ناو فودز', 'ناتشرز باونتي', 'سنتري'] %}
                                <label class="flex items-center gap-3 cursor-pointer group">
                                    <input type="checkbox" class="w-5 h-5 border border-black/10 rounded-md checked:bg-primary transition-all">
                                    <span class="text-sm text-text-muted group-hover:text-primary transition-colors">{{ brand }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                </aside>

                {# Main Content #}
                <div class="flex-grow space-y-12">
                    {# Header #}
                    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
                        <h1 class="text-2xl font-bold">الفيتامينات والمكملات الغذائية</h1>
                        <div class="flex items-center gap-4 w-full md:w-auto">
                            <span class="text-xs text-text-muted whitespace-nowrap">ترتيب حسب:</span>
                            <select class="w-full md:w-48 bg-white border border-black/5 rounded-lg px-4 py-3 text-sm outline-none focus:border-primary">
                                <option>الأكثر مبيعاً</option>
                                <option>الأحدث</option>
                                <option>السعر: من الأقل للأعلى</option>
                                <option>السعر: من الأعلى للأقل</option>
                            </select>
                        </div>
                    </div>

                    {# Grid #}
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                        {% for i in 1..9 %}
                            {% include 'shared.product-card' with { product: {
                                name: 'مكمل غذائي متعدد الفيتامينات - 100 كبسولة',
                                url: '/product',
                                image: {url: 'https://picsum.photos/seed/cat-prod-' ~ i ~ '/400/400'},
                                category: {name: 'الفيتامينات'},
                                price: 85,
                                on_sale: i % 3 == 0,
                                regular_price: 110,
                                requires_prescription: i == 5
                            }} %}
                        {% endfor %}
                    </div>

                    {# Pagination #}
                    <div class="flex items-center justify-center gap-2 pt-12 border-t border-black/5">
                        <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-white border border-black/5 text-text-muted hover:bg-primary hover:text-white transition-all"><i class="salla-icon-arrow-right"></i></button>
                        <span class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary text-white font-bold text-sm">1</span>
                        <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-white border border-black/5 text-text-muted hover:bg-primary hover:text-white transition-all">2</button>
                        <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-white border border-black/5 text-text-muted hover:bg-primary hover:text-white transition-all">3</button>
                        <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-white border border-black/5 text-text-muted hover:bg-primary hover:text-white transition-all"><i class="salla-icon-arrow-left"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
