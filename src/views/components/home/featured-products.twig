<section class="py-24 bg-white">
    <div class="container mx-auto px-4">
        {# Section Header #}
        <div class="flex flex-col md:flex-row items-end justify-between mb-12">
            <div class="max-w-xl">
                <span class="text-primary text-xs font-bold tracking-widest uppercase mb-4 block">Our Picks</span>
                <h2 class="text-3xl md:text-4xl font-bold">{{ component.title|default('Featured Products') }}</h2>
            </div>
            <a href="/products" class="text-sm font-bold text-primary hover:underline mt-4 md:mt-0 flex items-center">
                View All Products <i class="salla-icon-arrow-right ml-2"></i>
            </a>
        </div>

        {# Products Grid #}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for product in products.featured|slice(0, 4) %}
                {% include 'shared.product-card' with { product: product } %}
            {% else %}
                {# Placeholder for demo #}
                {% for i in 1..4 %}
                    <div class="animate-pulse">
                        <div class="bg-light aspect-square rounded-2xl mb-4"></div>
                        <div class="h-4 bg-light rounded w-1/2 mb-2"></div>
                        <div class="h-4 bg-light rounded w-full mb-4"></div>
                        <div class="h-8 bg-light rounded w-1/3"></div>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </div>
</section>
